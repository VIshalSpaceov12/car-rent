generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  PROVIDER
  STAFF
  ADMIN
}

enum Locale {
  EN
  AR
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum BookingStatus {
  RESERVED
  CONFIRMED
  VEHICLE_PREPARED
  PICKED_UP
  RETURNED
  COMPLETED
  REJECTED
  CANCELLED
}

enum RentalPlan {
  DAILY
  WEEKLY
  MONTHLY
  LONG_TERM
}

enum PaymentMethod {
  CARD
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReturnCondition {
  CLEAN
  MINOR_DAMAGE
  MAJOR_DAMAGE
}

enum SupportStatus {
  OPEN
  RESOLVED
}

enum DiscountKind {
  PERCENT
  FIXED
}

model Provider {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logoUrl       String?
  colors        Json
  defaultLocale Locale   @default(EN)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users              User[]
  businessSettings   BusinessSettings?
  vehicleCategories  VehicleCategory[]
  branches           Branch[]
  vehicles           Vehicle[]
  bookings           Booking[]
  payments           Payment[]
  otps               Otp[]
  contracts          Contract[]
  returnInspections  ReturnInspection[]
  supportTickets     SupportTicket[]
  discountCodes      DiscountCode[]
  maintenanceRecords MaintenanceRecord[]
}

model VehicleCategory {
  id         String   @id @default(cuid())
  providerId String
  name       String
  slug       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]

  @@unique([providerId, slug])
  @@index([providerId])
}

model Branch {
  id         String   @id @default(cuid())
  providerId String
  name       String
  address    String
  phone      String?
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]
  pickupBookings  Booking[] @relation("pickup")
  dropoffBookings Booking[] @relation("dropoff")

  @@index([providerId])
}

model Vehicle {
  id          String        @id @default(cuid())
  providerId  String
  categoryId  String
  branchId    String?
  name        String
  make        String?
  model       String?
  year        Int?
  transmission Transmission
  fuelType    FuelType
  status      VehicleStatus @default(ACTIVE)
  pricePerDay Decimal       @db.Decimal(10, 2)
  seats       Int?
  imageUrl    String?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  provider Provider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category VehicleCategory @relation(fields: [categoryId], references: [id])
  branch   Branch?         @relation(fields: [branchId], references: [id])
  bookings Booking[]
  otps     Otp[]
  maintenanceRecords MaintenanceRecord[]

  @@index([providerId])
  @@index([categoryId])
}

model BusinessSettings {
  id                 String   @id @default(cuid())
  providerId         String   @unique
  currency           String   @default("USD")
  taxRatePct         Decimal  @default(0) @db.Decimal(5, 2)
  minRentalDays      Int      @default(1)
  cancellationPolicy String   @default("")
  planMultipliers    Json     @default("{\"daily\":1,\"weekly\":0.9,\"monthly\":0.8,\"long-term\":0.7}")
  serviceChargePct   Decimal  @default(0) @db.Decimal(5, 2)

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(cuid())
  providerId   String?
  role         UserRole
  email        String   @unique
  passwordHash String
  name         String
  locale       Locale   @default(EN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  provider Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  sessions  Session[]
  bookings  Booking[]
  loyaltyAccount  LoyaltyAccount?
  loyaltyEntries  LoyaltyEntry[]
  addresses       Address[]
  supportTickets  SupportTicket[]

  @@index([providerId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Booking {
  id               String        @id @default(cuid())
  providerId       String
  customerId       String
  vehicleId        String
  pickupBranchId   String?
  dropoffBranchId  String?
  startDate        DateTime
  endDate          DateTime
  plan             RentalPlan
  status           BookingStatus @default(RESERVED)
  baseAmount       Decimal       @db.Decimal(10, 2)
  taxAmount        Decimal       @db.Decimal(10, 2)
  serviceCharge    Decimal       @db.Decimal(10, 2)
  totalAmount      Decimal       @db.Decimal(10, 2)
  currency         String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  provider      Provider         @relation(fields: [providerId], references: [id], onDelete: Cascade)
  customer      User             @relation(fields: [customerId], references: [id])
  vehicle       Vehicle          @relation(fields: [vehicleId], references: [id])
  pickupBranch  Branch?          @relation("pickup",  fields: [pickupBranchId],  references: [id])
  dropoffBranch Branch?          @relation("dropoff", fields: [dropoffBranchId], references: [id])
  payment       Payment?
  otp           Otp?
  contract      Contract?
  inspection    ReturnInspection?
  loyaltyEntries LoyaltyEntry[]

  @@index([providerId])
  @@index([customerId])
  @@index([vehicleId])
}

model Payment {
  id         String        @id @default(cuid())
  providerId String
  bookingId  String        @unique
  amount     Decimal       @db.Decimal(10, 2)
  currency   String
  method     PaymentMethod
  status     PaymentStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model Otp {
  id          String    @id @default(cuid())
  providerId  String
  bookingId   String    @unique
  vehicleId   String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([providerId])
}

model Contract {
  id            String    @id @default(cuid())
  providerId    String
  bookingId     String    @unique
  signatureName String?
  signedAt      DateTime?
  termsVersion  String
  createdAt     DateTime  @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model ReturnInspection {
  id          String          @id @default(cuid())
  providerId  String
  bookingId   String          @unique
  condition   ReturnCondition
  notes       String?
  inspectedAt DateTime        @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
}

model LoyaltyAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoyaltyEntry {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  bookingId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String
  line1     String
  city      String
  country   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SupportTicket {
  id         String        @id @default(cuid())
  providerId String
  userId     String
  subject    String
  body       String
  status     SupportStatus @default(OPEN)
  response   String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([userId])
}

model DiscountCode {
  id         String       @id @default(cuid())
  providerId String
  code       String
  kind       DiscountKind
  value      Decimal      @db.Decimal(10, 2)
  active     Boolean      @default(true)
  expiresAt  DateTime?
  createdAt  DateTime     @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, code])
  @@index([providerId])
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  providerId  String
  vehicleId   String
  description String
  date        DateTime
  cost        Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([vehicleId])
}

/// Singleton row (id = "singleton") for platform-level configuration.
model PlatformSettings {
  id            String   @id @default("singleton")
  platformName  String
  supportEmail  String
  defaultLocale Locale   @default(EN)
  updatedAt     DateTime @updatedAt
}
